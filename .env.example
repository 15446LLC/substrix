# Intuit OAuth 2.0 Credentials
# Copy this file to .env and fill in your values — never commit .env
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here
REDIRECT_URI=http://localhost:3000/callback
ENVIRONMENT=sandbox

# Session secret — use any long random string
SESSION_SECRET=change_me_to_something_random

# Postgres connection string (optional — without it, sessions are in-memory
# and event logging is disabled). Free options: Neon (neon.tech), Supabase.
# DATABASE_URL=postgres://user:pass@host/dbname

# Key for the /admin monitoring page — any long random string.
# Visit /admin?key=<this value> to view installs, activity, and errors.
# ADMIN_KEY=change_me_to_something_random
